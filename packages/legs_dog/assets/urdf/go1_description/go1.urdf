<?xml version="1.0" ?>
<!-- Unitree Go1 simplified URDF for PyBullet simulation.
     Joint layout: 4 legs × 3 joints (hip_ab, thigh, calf) = 12 DOF
     Based on official Go1 specs: body 0.3547×0.098×0.114m, ~12kg
-->
<robot name="go1">

  <!-- ==================== BASE ==================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.024" ixy="0" ixz="0" iyy="0.071" iyz="0" izz="0.08"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.36 0.10 0.114"/></geometry>
      <material name="body_color"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.36 0.10 0.114"/></geometry>
    </collision>
  </link>

  <!-- Hip offset from body center:
       FL: (+0.1881, +0.04675)  FR: (+0.1881, -0.04675)
       RL: (-0.1881, +0.04675)  RR: (-0.1881, -0.04675) -->

  <!-- ==================== FRONT LEFT (FL) ==================== -->
  <link name="FL_hip">
    <inertial><mass value="0.696"/><inertia ixx="0.000469" ixy="0" ixz="0" iyy="0.000807" iyz="0" izz="0.000552"/></inertial>
    <visual><origin xyz="0 0.04 0" rpy="0 0 0"/><geometry><cylinder radius="0.02" length="0.08"/></geometry><material name="hip_color"><color rgba="0.3 0.3 0.3 1.0"/></material></visual>
    <collision><origin xyz="0 0.04 0" rpy="0 0 0"/><geometry><cylinder radius="0.02" length="0.08"/></geometry></collision>
  </link>
  <joint name="FL_hip_joint" type="revolute">
    <parent link="base_link"/><child link="FL_hip"/>
    <origin xyz="0.1881 0.04675 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.863" upper="0.863" effort="23.7" velocity="30.1"/>
  </joint>

  <link name="FL_thigh">
    <inertial><mass value="1.013"/><inertia ixx="0.00552" ixy="0" ixz="0" iyy="0.00584" iyz="0" izz="0.000655"/></inertial>
    <visual><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.04 0.03 0.2"/></geometry><material name="thigh_color"><color rgba="0.4 0.4 0.4 1.0"/></material></visual>
    <collision><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.04 0.03 0.2"/></geometry></collision>
  </link>
  <joint name="FL_thigh_joint" type="revolute">
    <parent link="FL_hip"/><child link="FL_thigh"/>
    <origin xyz="0 0.08 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.686" upper="4.501" effort="23.7" velocity="30.1"/>
  </joint>

  <link name="FL_calf">
    <inertial><mass value="0.166"/><inertia ixx="0.00299" ixy="0" ixz="0" iyy="0.00305" iyz="0" izz="0.0000953"/></inertial>
    <visual><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.03 0.02 0.2"/></geometry><material name="calf_color"><color rgba="0.5 0.5 0.5 1.0"/></material></visual>
    <collision><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.03 0.02 0.2"/></geometry></collision>
  </link>
  <joint name="FL_calf_joint" type="revolute">
    <parent link="FL_thigh"/><child link="FL_calf"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.818" upper="-0.888" effort="35.55" velocity="20.06"/>
  </joint>

  <link name="FL_foot">
    <inertial><mass value="0.06"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><sphere radius="0.02"/></geometry><material name="foot_color"><color rgba="0.1 0.1 0.1 1.0"/></material></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/><geometry><sphere radius="0.02"/></geometry></collision>
  </link>
  <joint name="FL_foot_joint" type="fixed">
    <parent link="FL_calf"/><child link="FL_foot"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
  </joint>

  <!-- ==================== FRONT RIGHT (FR) ==================== -->
  <link name="FR_hip">
    <inertial><mass value="0.696"/><inertia ixx="0.000469" ixy="0" ixz="0" iyy="0.000807" iyz="0" izz="0.000552"/></inertial>
    <visual><origin xyz="0 -0.04 0" rpy="0 0 0"/><geometry><cylinder radius="0.02" length="0.08"/></geometry><material name="hip_color"/></visual>
    <collision><origin xyz="0 -0.04 0" rpy="0 0 0"/><geometry><cylinder radius="0.02" length="0.08"/></geometry></collision>
  </link>
  <joint name="FR_hip_joint" type="revolute">
    <parent link="base_link"/><child link="FR_hip"/>
    <origin xyz="0.1881 -0.04675 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.863" upper="0.863" effort="23.7" velocity="30.1"/>
  </joint>

  <link name="FR_thigh">
    <inertial><mass value="1.013"/><inertia ixx="0.00552" ixy="0" ixz="0" iyy="0.00584" iyz="0" izz="0.000655"/></inertial>
    <visual><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.04 0.03 0.2"/></geometry><material name="thigh_color"/></visual>
    <collision><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.04 0.03 0.2"/></geometry></collision>
  </link>
  <joint name="FR_thigh_joint" type="revolute">
    <parent link="FR_hip"/><child link="FR_thigh"/>
    <origin xyz="0 -0.08 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.686" upper="4.501" effort="23.7" velocity="30.1"/>
  </joint>

  <link name="FR_calf">
    <inertial><mass value="0.166"/><inertia ixx="0.00299" ixy="0" ixz="0" iyy="0.00305" iyz="0" izz="0.0000953"/></inertial>
    <visual><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.03 0.02 0.2"/></geometry><material name="calf_color"/></visual>
    <collision><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.03 0.02 0.2"/></geometry></collision>
  </link>
  <joint name="FR_calf_joint" type="revolute">
    <parent link="FR_thigh"/><child link="FR_calf"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.818" upper="-0.888" effort="35.55" velocity="20.06"/>
  </joint>

  <link name="FR_foot">
    <inertial><mass value="0.06"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
    <visual><geometry><sphere radius="0.02"/></geometry><material name="foot_color"/></visual>
    <collision><geometry><sphere radius="0.02"/></geometry></collision>
  </link>
  <joint name="FR_foot_joint" type="fixed">
    <parent link="FR_calf"/><child link="FR_foot"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
  </joint>

  <!-- ==================== REAR LEFT (RL) ==================== -->
  <link name="RL_hip">
    <inertial><mass value="0.696"/><inertia ixx="0.000469" ixy="0" ixz="0" iyy="0.000807" iyz="0" izz="0.000552"/></inertial>
    <visual><origin xyz="0 0.04 0" rpy="0 0 0"/><geometry><cylinder radius="0.02" length="0.08"/></geometry><material name="hip_color"/></visual>
    <collision><origin xyz="0 0.04 0" rpy="0 0 0"/><geometry><cylinder radius="0.02" length="0.08"/></geometry></collision>
  </link>
  <joint name="RL_hip_joint" type="revolute">
    <parent link="base_link"/><child link="RL_hip"/>
    <origin xyz="-0.1881 0.04675 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.863" upper="0.863" effort="23.7" velocity="30.1"/>
  </joint>

  <link name="RL_thigh">
    <inertial><mass value="1.013"/><inertia ixx="0.00552" ixy="0" ixz="0" iyy="0.00584" iyz="0" izz="0.000655"/></inertial>
    <visual><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.04 0.03 0.2"/></geometry><material name="thigh_color"/></visual>
    <collision><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.04 0.03 0.2"/></geometry></collision>
  </link>
  <joint name="RL_thigh_joint" type="revolute">
    <parent link="RL_hip"/><child link="RL_thigh"/>
    <origin xyz="0 0.08 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.686" upper="4.501" effort="23.7" velocity="30.1"/>
  </joint>

  <link name="RL_calf">
    <inertial><mass value="0.166"/><inertia ixx="0.00299" ixy="0" ixz="0" iyy="0.00305" iyz="0" izz="0.0000953"/></inertial>
    <visual><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.03 0.02 0.2"/></geometry><material name="calf_color"/></visual>
    <collision><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.03 0.02 0.2"/></geometry></collision>
  </link>
  <joint name="RL_calf_joint" type="revolute">
    <parent link="RL_thigh"/><child link="RL_calf"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.818" upper="-0.888" effort="35.55" velocity="20.06"/>
  </joint>

  <link name="RL_foot">
    <inertial><mass value="0.06"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
    <visual><geometry><sphere radius="0.02"/></geometry><material name="foot_color"/></visual>
    <collision><geometry><sphere radius="0.02"/></geometry></collision>
  </link>
  <joint name="RL_foot_joint" type="fixed">
    <parent link="RL_calf"/><child link="RL_foot"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
  </joint>

  <!-- ==================== REAR RIGHT (RR) ==================== -->
  <link name="RR_hip">
    <inertial><mass value="0.696"/><inertia ixx="0.000469" ixy="0" ixz="0" iyy="0.000807" iyz="0" izz="0.000552"/></inertial>
    <visual><origin xyz="0 -0.04 0" rpy="0 0 0"/><geometry><cylinder radius="0.02" length="0.08"/></geometry><material name="hip_color"/></visual>
    <collision><origin xyz="0 -0.04 0" rpy="0 0 0"/><geometry><cylinder radius="0.02" length="0.08"/></geometry></collision>
  </link>
  <joint name="RR_hip_joint" type="revolute">
    <parent link="base_link"/><child link="RR_hip"/>
    <origin xyz="-0.1881 -0.04675 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.863" upper="0.863" effort="23.7" velocity="30.1"/>
  </joint>

  <link name="RR_thigh">
    <inertial><mass value="1.013"/><inertia ixx="0.00552" ixy="0" ixz="0" iyy="0.00584" iyz="0" izz="0.000655"/></inertial>
    <visual><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.04 0.03 0.2"/></geometry><material name="thigh_color"/></visual>
    <collision><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.04 0.03 0.2"/></geometry></collision>
  </link>
  <joint name="RR_thigh_joint" type="revolute">
    <parent link="RR_hip"/><child link="RR_thigh"/>
    <origin xyz="0 -0.08 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.686" upper="4.501" effort="23.7" velocity="30.1"/>
  </joint>

  <link name="RR_calf">
    <inertial><mass value="0.166"/><inertia ixx="0.00299" ixy="0" ixz="0" iyy="0.00305" iyz="0" izz="0.0000953"/></inertial>
    <visual><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.03 0.02 0.2"/></geometry><material name="calf_color"/></visual>
    <collision><origin xyz="0 0 -0.1" rpy="0 0 0"/><geometry><box size="0.03 0.02 0.2"/></geometry></collision>
  </link>
  <joint name="RR_calf_joint" type="revolute">
    <parent link="RR_thigh"/><child link="RR_calf"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.818" upper="-0.888" effort="35.55" velocity="20.06"/>
  </joint>

  <link name="RR_foot">
    <inertial><mass value="0.06"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
    <visual><geometry><sphere radius="0.02"/></geometry><material name="foot_color"/></visual>
    <collision><geometry><sphere radius="0.02"/></geometry></collision>
  </link>
  <joint name="RR_foot_joint" type="fixed">
    <parent link="RR_calf"/><child link="RR_foot"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
  </joint>

</robot>
